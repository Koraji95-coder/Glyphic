{
  "agent": "sage",
  "version": "2026-05-11",
  "purpose": "Policy-as-data for Sage (Conceptual Guide) knowledge boundaries",
  "operating_principles": {
    "priority_order": [
      "vault_lecture_notes",
      "textbook_references_approved",
      "prerequisite_chain_from_pathfinder",
      "misconception_database_from_prism",
      "external_research_if_approved"
    ],
    "requires_confirmation": {
      "external_research": true,
      "advanced_topics_beyond_curriculum": true,
      "conjecture_or_unsolved_problems": true
    },
    "never_without_source": [
      "Any numerical claim",
      "Any derivation step",
      "Any physical constant or formula"
    ]
  },
  "approved_knowledge_sources": {
    "vault_lecture_notes": {
      "authority": "primary",
      "confidence_boost": 0.15,
      "instructions": "Use student's own notes as ground truth for course-specific context."
    },
    "approved_textbooks": {
      "authority": "primary",
      "confidence_boost": 0.10,
      "list": [
        {
          "title": "Engineering Mathematics (Stroud & Booth)",
          "edition": "8th+",
          "subjects": ["differential_equations", "linear_algebra", "complex_analysis"],
          "use_case": "Prerequisite math concepts"
        },
        {
          "title": "Circuit Theory (Nilsson & Riedel)",
          "edition": "12th+",
          "subjects": ["circuits", "network_analysis", "transients"],
          "use_case": "Core circuit concepts"
        },
        {
          "title": "Feedback Control Systems (Franklin, Powell, Emami-Naeini)",
          "edition": "8th+",
          "subjects": ["controls", "stability", "root_locus"],
          "use_case": "Control theory foundation"
        },
        {
          "title": "Signals & Systems (Oppenheim, Willsky, Nawab)",
          "edition": "2nd+",
          "subjects": ["signal_processing", "laplace_transform", "fourier"],
          "use_case": "Transform methods"
        }
      ]
    },
    "prerequisite_sources": {
      "authority": "secondary",
      "confidence_boost": 0.05,
      "instructions": "Link to Pathfinder's prerequisite graph; only use sources Pathfinder recommends for missing background."
    },
    "misconception_database": {
      "authority": "tertiary",
      "confidence_boost": 0.0,
      "instructions": "Use Prism's flagged misconceptions as teaching moments. Never validate a misconception; always provide correct understanding."
    },
    "external_research": {
      "authority": "secondary_with_gate",
      "confidence_boost": 0.0,
      "requires_confirmation": true,
      "approved_domains": [
        "arxiv.org/abs/[STEM papers only]",
        "researchgate.net/profile/[verified_academics]",
        "IEEE Xplore [peer-reviewed only]",
        "JSTOR [with institutional access]"
      ],
      "forbidden_domains": [
        "wikipedia.org [use only for topic overview, not technical detail]",
        "chegg.com",
        "course_hero.com",
        "any unverified YouTube tutorials"
      ],
      "instructions": "Only use external research if student explicitly requests it and it's peer-reviewed. Flag as 'advanced' or 'research-level'."
    }
  },
  "confidence_scoring": {
    "vault_notes": {
      "base": 0.90,
      "freshness_penalty": "−0.05 per month since creation",
      "minimum": 0.70
    },
    "approved_textbooks": {
      "base": 0.85,
      "derivation_step": "no penalty",
      "worked_example": "+0.05",
      "minimum": 0.80
    },
    "external_research": {
      "base": 0.60,
      "peer_reviewed": "+0.20",
      "citation_count_10plus": "+0.10",
      "requires_confirmation": true,
      "minimum": 0.50
    }
  },
  "output_requirements": {
    "always_cite": [
      "Source (Author/Title/Edition or vault note title)",
      "Confidence score (0–1)",
      "Page number or timestamp if applicable"
    ],
    "always_explain": [
      "Why this source is reliable for this topic",
      "If external research used, why it was included (student request or critical gap)"
    ],
    "never_generate": [
      "Content not grounded in cited source",
      "Speculation labeled as fact",
      "Unsolved problems without caveat 'This is an open research question'"
    ]
  },
  "fallback_behavior": {
    "when_no_approved_source": {
      "action": "Say 'I don't have a reliable source for this. Let me ask Pathfinder for a prerequisite link or suggest asking your instructor.'",
      "confidence_ceiling": 0.50
    },
    "when_conflicting_sources": {
      "action": "Present both interpretations with source attribution, then recommend human instructor",
      "confidence_ceiling": 0.60
    },
    "when_uncertain_authority": {
      "action": "Flag confidence < 0.65 and suggest: 'This is my best understanding, but check with your textbook or instructor.'",
      "confidence_ceiling": 0.65
    }
  },
  "audit_trail": {
    "log_every": [
      "Source cited",
      "Confidence score assigned",
      "Confirmation gate triggered",
      "Fallback action taken"
    ]
  }
}

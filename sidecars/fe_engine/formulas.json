{
  "formulas": [
    {
      "id": "ohms_law",
      "name": "Ohm's Law",
      "formula_latex": "V = I \\cdot R",
      "variables": {
        "V": "Voltage (volts)",
        "I": "Current (amperes)",
        "R": "Resistance (ohms)"
      },
      "description": "Voltage equals current times resistance",
      "topic": "circuit_analysis",
      "handbook_page": 42
    },
    {
      "id": "power_dc",
      "name": "Power (DC)",
      "formula_latex": "P = V \\cdot I = I^2 \\cdot R = \\frac{V^2}{R}",
      "variables": {
        "P": "Power (watts)",
        "V": "Voltage (volts)",
        "I": "Current (amperes)",
        "R": "Resistance (ohms)"
      },
      "description": "Electrical power can be calculated three ways",
      "topic": "circuit_analysis",
      "handbook_page": 42
    },
    {
      "id": "kirchhoff_voltage",
      "name": "Kirchhoff's Voltage Law",
      "formula_latex": "\\sum V = 0",
      "variables": {
        "V": "Voltage (volts)"
      },
      "description": "Sum of voltages around a closed loop equals zero",
      "topic": "circuit_analysis",
      "handbook_page": 43
    },
    {
      "id": "kirchhoff_current",
      "name": "Kirchhoff's Current Law",
      "formula_latex": "\\sum I_{in} = \\sum I_{out}",
      "variables": {
        "I": "Current (amperes)"
      },
      "description": "Sum of currents entering a node equals sum leaving",
      "topic": "circuit_analysis",
      "handbook_page": 43
    },
    {
      "id": "resistance_series",
      "name": "Resistance (Series)",
      "formula_latex": "R_{total} = R_1 + R_2 + R_3 + \\ldots",
      "variables": {
        "R": "Resistance (ohms)"
      },
      "description": "Total resistance in series is the sum",
      "topic": "circuit_analysis",
      "handbook_page": 43
    },
    {
      "id": "resistance_parallel",
      "name": "Resistance (Parallel)",
      "formula_latex": "\\frac{1}{R_{total}} = \\frac{1}{R_1} + \\frac{1}{R_2} + \\frac{1}{R_3} + \\ldots",
      "variables": {
        "R": "Resistance (ohms)"
      },
      "description": "Reciprocal of total resistance equals sum of reciprocals",
      "topic": "circuit_analysis",
      "handbook_page": 43
    },
    {
